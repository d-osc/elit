{
  "name": "my-elit-app",
  "version": "0.0.0",
  "dependencies": {
    "@types/node": "^25.0.9",
    "elit": "file:../../"
  },
  "scripts": {
    "dev": "elit dev",
    "build": "elit build",
    "build:dev": "elit build-dev",
    "preview": "elit preview",
    "build:preview": "elit build-preview",
    "wapk:pack": "npm run build:preview && elit wapk pack ./",
    "wapk:pack:dev": "npm run build:dev && elit wapk pack ./",
    "wapk:run": "elit wapk run ./elit-full-db-example.wapk",
    "wapk:inspect": "elit wapk inspect ./elit-full-db-example.wapk",
    "test": "elit test",
    "test:watch": "elit test --watch",
    "test:coverage": "elit test --coverage"
  },
  "type": "module"
}
