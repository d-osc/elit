{
  "name": "@elit/wapk-google-drive-example",
  "version": "1.0.0",
  "description": "Example Elit app configured to run a WAPK archive directly from Google Drive",
  "type": "module",
  "scripts": {
    "pack": "elit wapk pack .",
    "run": "elit wapk",
    "pm:start:direct": "node ./scripts/pm-start-direct.mjs",
    "pm:start:config": "node ./scripts/pm-start-config.mjs",
    "pm:list": "node ./scripts/pm-runner.mjs list",
    "pm:logs": "node ./scripts/pm-runner.mjs logs drive-app"
  },
  "keywords": [
    "elit",
    "wapk",
    "google-drive",
    "example"
  ],
  "license": "MIT"
}