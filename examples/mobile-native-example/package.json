{
  "name": "example-mobile-native",
  "version": "0.0.0",
  "private": true,
  "description": "Native mobile example for elit mobile workflow",
  "scripts": {
    "mobile:init": "bun ../../src/cli.ts mobile init . --app-id com.elit.mobileexample --app-name ElitMobileExample --web-dir web",
    "mobile:sync": "bun ../../src/cli.ts mobile sync --cwd . --web-dir web",
    "mobile:doctor": "bun ../../src/cli.ts mobile doctor --cwd . --json",
    "mobile:test:win": "powershell -ExecutionPolicy Bypass -File ./test-mobile.ps1",
    "mobile:build:android": "bun ../../src/cli.ts mobile run android --cwd .",
    "mobile:build:ios": "bun ../../src/cli.ts mobile run ios --cwd ."
  },
  "devDependencies": {
    "elit": "file:../.."
  }
}
